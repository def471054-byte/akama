generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  password String
  role     String
}

model Employee {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String?
  phone             String?
  permitNumber      String?
  idNumber          String?
  nationality       String?
  gender            String?
  issueDate         DateTime?
  expiryDate        DateTime?
  company           String?
  authority         String?
  purpose           String?
  description       String?
  designation       String?
  department        String?
  photo             String?
  bloodType         String?
  birthDate         DateTime?
  providerEstNumber String?
  beneficiaryEstName String?
  beneficiaryEstNumber String?
  workLocations     String?
  ajeerId           String?  @unique
  verificationToken String?  @unique
  createdAt         DateTime @default(now())
}
